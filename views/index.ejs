<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <title>Post-its</title>
  <link rel="stylesheet" href="/style.css">
  <style>
    .board {
      background: <%= preferences?.couleurFond || "#f4f4f4" %>;
    }
    .postit {
      background: <%= preferences?.couleurPostit || "#ffeb3b" %>;
      border-color: <%= preferences?.couleurPostit || "#ffeb3b" %>;
    }
  </style>
</head>
<body>

  <div class="topbar">
    <h1>📌 Post-its</h1>

    <% if (user && user.login !== 'guest') { %>
      <span>Connecté en tant que <strong id="span-login"><%= user.login %></strong></span>
      <% if (user.droits && user.droits.administration) { %>
        <a href="/admin" class="btn btn-secondary">⚙️ Admin</a>
      <% } %>
      <button class="btn btn-secondary" onclick="toggleReglages()">🎨 Réglages</button>
      <a href="/logout" class="btn">Se déconnecter</a>
    <% } else { %>
      <form method="POST" action="/login" class="login-form">
        <input type="text" name="login" placeholder="Login" required>
        <input type="password" name="password" placeholder="Mot de passe" required>
        <button type="submit" class="btn">Se connecter</button>
        <a href="/signup" class="btn btn-secondary">S'inscrire</a>
      </form>
    <% } %>
  </div>

  <!-- Panel réglages -->
  <div id="panel-reglages" class="panel-reglages hidden">
    <h2>Réglages</h2>

    <div class="panel-section">
      <h3>Changer le login</h3>
      <input type="text" id="nouveau-login" placeholder="Nouveau login">
      <button class="btn" onclick="changerLogin()">Sauvegarder</button>
      <p class="feedback" id="feedback-login"></p>
    </div>

    <div class="panel-section">
      <h3>Changer le mot de passe</h3>
      <input type="password" id="ancien-password" placeholder="Ancien mot de passe">
      <input type="password" id="nouveau-password" placeholder="Nouveau mot de passe">
      <button class="btn" onclick="changerPassword()">Sauvegarder</button>
      <p class="feedback" id="feedback-password"></p>
    </div>

    <div class="panel-section">
      <h3>Apparence</h3>
      <label>Couleur du fond</label>
      <input type="color" id="couleur-fond" value="<%= preferences.couleurFond %>">
      <label>Couleur des post-its</label>
      <input type="color" id="couleur-postit" value="<%= preferences.couleurPostit %>">
      <button class="btn" onclick="sauvegarderCouleurs()">Sauvegarder les couleurs</button>
      <p class="feedback" id="feedback-couleurs"></p>
    </div>

    <button class="btn btn-secondary" style="width:100%;margin-top:8px" onclick="toggleReglages()">Fermer</button>
  </div>

  <!-- Overlay pour fermer le panel en cliquant à côté -->
  <div id="overlay-reglages" class="overlay hidden" onclick="toggleReglages()"></div>

  <div class="board">
    <% postits.forEach(postit => { %>
      <% 
        // Calcul des droits pour ce post-it précis
        let estAuteur = (user && user.id === postit.auteur_id);
        let estAdmin = (user && user.droits && user.droits.administration == 1);
        let droitGlobal = estAuteur || estAdmin;
      %>
      
      <div class="postit <%= droitGlobal ? 'modifiable' : '' %>"
          style="left: <%= postit.x %>px; top: <%= postit.y %>px; z-index: <%= postit.zIndex %>;"
          data-id="<%= postit.id %>">
        
        <p class="postit-texte"><%= postit.texte %></p>
        <p class="postit-meta"><%= postit.auteur %> — <%= new Date(postit.date).toLocaleString('fr-FR') %></p>
        
        <% if (droitGlobal) { %>
          <button class="supprimer" data-id="<%= postit.id %>">×</button>
        <% } %>
      </div>
    <% }) %>
  </div>

  <div id="popup" class="popup hidden">
    <textarea id="popup-texte" placeholder="Votre message..."></textarea>
    <div class="popup-boutons">
      <button id="popup-valider" class="btn">Ajouter</button>
      <button id="popup-annuler" class="btn btn-secondary">Annuler</button>
    </div>
  </div>

  
  <script>
    window.currentUser = {
      id: <%= user ? user.id : 'null' %>,
      // On force la conversion en booléen JS
      isAdmin: <%= (user && user.droits && user.droits.administration) ? 'true' : 'false' %>
    };
  </script>
  <script src="/main.js"></script>
</body>
</html>
<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <title>Inscription - Post-its</title>
  <link rel="stylesheet" href="/style.css">
</head>
<body class="auth-page">
  <div class="auth-container">
    <div class="auth-card">
      <h1>✨ Créer un compte</h1>
      <p class="subtitle">Rejoignez la communauté des post-its !</p>

      <% if (error) { %>
        <div class="error-box">
          <p class="error"><%= error %></p>
        </div>
      <% } %>

      <form method="POST" action="/signup" class="vertical-form">
        <div class="input-group">
          <label for="login">Identifiant</label>
          <input type="text" id="login" name="login" placeholder="Choisissez un pseudo" required autofocus>
        </div>

        <div class="input-group">
          <label for="password">Mot de passe</label>
          <input type="password" id="password" name="password" placeholder="Ménagez vos secrets..." required>
        </div>

        <button type="submit" class="btn btn-primary">S'inscrire</button>
      </form>

      <hr>

      <div class="auth-footer">
        <p>Déjà un compte ? <a href="/">Connectez-vous ici</a></p>
      </div>
    </div>
  </div>
</body>
</html>